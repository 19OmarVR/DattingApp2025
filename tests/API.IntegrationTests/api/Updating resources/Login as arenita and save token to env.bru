meta {
  name: Login as arenita and save token to env
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/account/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "arenita@test.com",
    "password": "password"
  }
}

vars:pre-request {
  baseUrl: https://localhost:5001
}

tests {
  test("Should be able to login", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  const data = res.body;
  bru.setEnvVar('arenitaToken', data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
